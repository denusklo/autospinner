{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^(Bash|shell_command|exec_command|apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "node $(git rev-parse --show-toplevel)/.codex/hooks/pre-tool-use-guard.js",
            "commandWindows": "node C:\\Projects\\autospinner\\.codex\\hooks\\pre-tool-use-guard.js",
            "timeout": 10,
            "statusMessage": "Checking autospinner repository safety policy"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node $(git rev-parse --show-toplevel)/.codex/hooks/completion-evidence-guard.js",
            "commandWindows": "node C:\\Projects\\autospinner\\.codex\\hooks\\completion-evidence-guard.js",
            "timeout": 10,
            "statusMessage": "Checking completion evidence"
          }
        ]
      }
    ]
  }
}
